#!/bin/bash
# qnt-shield-fix
# Automated security remediation tool for QNT

BASE_DIR="/Users/aatifquamre/masterbot"
cd "$BASE_DIR"

echo "🛠️ QNT Shield Fix: Starting automated remediation..."

# 1. Fix .env permissions
if [ -f .env ]; then
    echo "• Setting .env permissions to 600..."
    chmod 600 .env
fi

# 2. Fix .gitignore if .env is missing
if ! grep -q "^\.env" .gitignore; then
    echo "• Adding .env to .gitignore..."
    echo ".env" >> .gitignore
fi

# 3. Check for .env in git cache (unstaging if tracked)
if git ls-files .env | grep -q ".env"; then
    echo "⚠️ ALERT: .env is currently tracked by Git."
    echo "• Unstaging .env..."
    git rm --cached .env
    echo "• Added to .gitignore. You must commit this change."
fi

# 4. Verification
echo -e "\n🛡️ Remediation complete. Running verification..."
/Users/aatifquamre/masterbot/qnt/bin/qnt-audit quick

#!/bin/bash
# qnt-audit [full|quick]
# Unified Security & Permission Auditor for MasterBot

BASE_DIR="/Users/aatifquamre/masterbot"
cd "$BASE_DIR"

# 1. Run the Shell Security Check
echo "🛡️ Running System Security Audit..."
/bin/bash "$BASE_DIR/automation/security_check.sh"
SHELL_EXIT=$?

echo -e "\n🔑 Verifying API Permissions..."
# 2. Run the API Permission Check
"$BASE_DIR/qnt/bin/qnt-python" "$BASE_DIR/automation/verify_api_permissions.py"
API_EXIT=$?

echo -e "\n🕵️ Scanning for Sensitive Leaks..."
# 3. Check for .env in git history
if git log --all -- .env | grep -q "commit"; then
    echo -e "[\033[0;31mFAIL\033[0m] Sensitive file .env was found in Git history! Use BFG or git-filter-repo to purge it."
    LEAK_EXIT=1
else
    echo -e "[\033[0;32mPASS\033[0m] No .env leaks found in Git history."
    LEAK_EXIT=0
fi

if [ $SHELL_EXIT -eq 0 ] && [ $API_EXIT -eq 0 ] && [ $LEAK_EXIT -eq 0 ]; then
    echo -e "\n✅ QNT-AUDIT: SYSTEM SECURE"
    exit 0
else
    echo -e "\n❌ QNT-AUDIT: SECURITY VULNERABILITIES FOUND"
    echo "Run 'qnt-shield-fix' to attempt automated remediation."
    exit 1
fi

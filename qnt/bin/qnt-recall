#!/bin/bash
set -a
source /Users/aatifquamre/masterbot/.env
set +a
QUERY="$*"
if [ -z "$QUERY" ]; then
  echo "Usage: qnt-recall <search query>"
  echo "Example: qnt-recall what happened during CPI releases"
  exit 1
fi
qnt-python -c "
import sys
sys.path.insert(0, '/Users/aatifquamre/masterbot/qnt/vault')
sys.path.insert(0, '/Users/aatifquamre/masterbot/qnt/memory')
from vault import search, format_results
results = search('''$QUERY''')
print(format_results(results))
"

#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
set -a
source $BASE_DIR/.env
set +a
STRATEGY_FILE=${1}
if [ -z "$STRATEGY_FILE" ]; then
  echo "Usage: qnt-deploy <strategy_file>"
  echo "Example: qnt-deploy strategies/candidates/Auto20260502_rsi.py"
  exit 1
fi
$BASE_DIR/qnt/bin/qnt-python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/lab')
sys.path.insert(0, '$BASE_DIR/qnt/memory')
sys.path.insert(0, '$BASE_DIR/qnt/bridge')
sys.path.insert(0, '$BASE_DIR/qnt/shield')
from lab import deploy_strategy
deploy_strategy('$STRATEGY_FILE')
"

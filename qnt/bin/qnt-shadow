#!/bin/bash
# qnt-shadow — Control and monitor Shadow Hyperopt on M2
set -a
source /Users/aatifquamre/cipher/.env
set +a

M2_USER="azmatsaif"
M2_PATH="/Users/azmatsaif/cipher"
M2_IP=$(tailscale ip azmatsaif-m2 2>/dev/null || grep M2_TAILSCALE_IP /Users/aatifquamre/cipher/.env | cut -d= -f2)

case "$1" in
  status)
    echo "🌑 Shadow Hyperopt Status"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━"
    ssh $M2_USER@$M2_IP "$M2_PATH/venv/bin/python $M2_PATH/qnt/shadow/resource_monitor.py" 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(f\"RAM: {d['ram_percent']:.1f}% ({d['ram_available_gb']:.1f}GB free)\")
    print(f\"CPU: {d['cpu_percent']:.1f}%\")
    print(f\"Swap: {d['swap_percent']:.1f}%\")
    print(f\"Throttled: {'⚠️ YES' if d['throttled'] else '✅ No'}\")
    print(f\"Pressure: {d['pressure'].upper()}\")
except:
    print('Error: Could not parse resource state from M2')
"
    echo ""
    echo "Process status:"
    ssh $M2_USER@$M2_IP "pgrep -f shadow_hyperopt.py && echo '✅ RUNNING' || echo '⏸️  STOPPED'"
    ;;
    
  report)
    echo "📊 Shadow Hyperopt Report (last 24h)"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    ssh $M2_USER@$M2_IP "tail -100 $M2_PATH/logs/shadow_hyperopt_*.log 2>/dev/null | grep -E '(Sharpe|improvement|SKIPPED|ERROR)' | tail -20"
    ;;
    
  start)
    echo "🚀 Starting Shadow Hyperopt on M2..."
    ssh $M2_USER@$M2_IP "
      cd $M2_PATH &&
      source venv/bin/activate &&
      nohup python3 qnt/shadow/shadow_hyperopt.py >> logs/shadow_hyperopt_main.log 2>&1 &
      echo \$! > logs/shadow_hyperopt.pid &&
      echo \"Started with PID \$(cat logs/shadow_hyperopt.pid)\"
    "
    ;;
    
  stop)
    echo "⏹️  Stopping Shadow Hyperopt on M2..."
    ssh $M2_USER@$M2_IP "
      if [ -f $M2_PATH/logs/shadow_hyperopt.pid ]; then
        kill \$(cat $M2_PATH/logs/shadow_hyperopt.pid) 2>/dev/null &&
        rm $M2_PATH/logs/shadow_hyperopt.pid &&
        echo 'Stopped' || echo 'Already stopped'
      else
        pkill -f shadow_hyperopt.py && echo 'Stopped by name' || echo 'Not running'
      fi
    "
    ;;
    
  promote)
    if [ -z "$2" ]; then
      echo "Usage: qnt-shadow promote <strategy_name>"
      exit 1
    fi
    echo "🔄 Promoting $2 parameters from Shadow to Active..."
    # This would copy optimized params from shadow results to active strategy
    # For now, log the request and notify for manual review
    ssh $M2_USER@$M2_IP "
      echo \"[$(date)] PROMOTE_REQUEST: $2\" >> $M2_PATH/logs/shadow_promotions.log
    "
    echo "✅ Promotion request logged. Review $M2_PATH/logs/shadow_promotions.log on M2."
    echo "⚠️  Manual parameter merge required — auto-deploy disabled for safety."
    ;;
    
  *)
    echo "qnt-shadow — Shadow Hyperopt controller"
    echo ""
    echo "Usage: qnt-shadow <command> [args]"
    echo ""
    echo "Commands:"
    echo "  status     — Show M2 resource usage and process state"
    echo "  report     — Show recent optimization results"
    echo "  start      — Launch continuous optimization loop"
    echo "  stop       — Halt the shadow loop"
    echo "  promote <strategy> — Flag improved params for review"
    echo ""
    echo "Examples:"
    echo "  qnt-shadow status"
    echo "  qnt-shadow report"
    echo "  qnt-shadow start"
    echo "  qnt-shadow promote MicroScalpV1"
    ;;
esac

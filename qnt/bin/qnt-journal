#!/bin/bash
set -a
source /Users/aatifquamre/masterbot/.env
set +a
NOTE="$*"
if [ -z "$NOTE" ]; then
  echo "Usage: qnt-journal <your note>"
  echo "Example: qnt-journal BTC dropped because of Fed announcement"
  exit 1
fi
qnt-python -c "
import sys
sys.path.insert(0, '/Users/aatifquamre/masterbot/qnt/vault')
sys.path.insert(0, '/Users/aatifquamre/masterbot/qnt/memory')
from vault import journal_entry
print(journal_entry('''$NOTE'''))
"

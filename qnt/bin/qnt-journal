#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# qnt-journal "your manual insight here"

set -a
source $BASE_DIR/.env
set +a

NOTE="$1"
if [ -z "$NOTE" ]; then
    echo "Usage: qnt-journal \"your insight here\""
    exit 1
fi

ID="manual_$(date +%s)"
TS="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

ssh azmatsaif@100.74.110.36 "
$BASE_DIR/venv/bin/python -c \"
import sys
sys.path.insert(0, '$BASE_DIR/qnt/vault')
from vault import store_lesson
store_lesson('$ID', '$NOTE', {'type':'manual_journal', 'close_date':'$TS'})
print('Insight saved to The Vault.')
\"
"

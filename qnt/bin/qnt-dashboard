#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
set -a
source $BASE_DIR/.env
set +a

echo "Starting QNT Dashboard..."
echo "Press 'q' to exit (or Ctrl+C for fallback)"
sleep 1

# Try full TUI first, fallback to static if it fails or if redirected
$BASE_DIR/qnt/bin/qnt-python $BASE_DIR/qnt/cockpit/cockpit.py 2>/dev/null || $BASE_DIR/venv/bin/python $BASE_DIR/qnt/cockpit/cockpit_static.py

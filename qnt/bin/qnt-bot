#!/bin/bash
# qnt bot [start|stop|restart|status|killswitch]
# Works from M1 or M2

set -a
source /Users/aatifquamre/masterbot/.env
set +a

COMMAND=${1:-status}
MODE=${2:-paper}

python3 -c "
import sys
sys.path.insert(0, '/Users/aatifquamre/masterbot/qnt/bridge')
sys.path.insert(0, '/Users/aatifquamre/masterbot/qnt/memory')
from bridge import bot_status, bot_start, bot_stop, bot_restart, killswitch

cmd = '$COMMAND'
if cmd == 'status':    print(bot_status())
elif cmd == 'start':   bot_start('$MODE')
elif cmd == 'stop':    bot_stop()
elif cmd == 'restart': bot_restart()
elif cmd == 'killswitch': killswitch()
else: print(f'Unknown command: {cmd}')
"

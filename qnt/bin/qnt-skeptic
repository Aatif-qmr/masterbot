#!/bin/bash
# qnt-skeptic — Control and monitor Adversarial Skeptic Agent
set -a
source /Users/aatifquamre/cipher/.env
set +a

BASE_DIR="/Users/aatifquamre/cipher"
SUBCMD=${1:-stats}

case $SUBCMD in
  stats)
    $BASE_DIR/venv/bin/python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/agents')
sys.path.insert(0, '$BASE_DIR/qnt/memory')
from trade_gate import get_skeptic_stats
print(get_skeptic_stats())
"
    ;;
  log)
    if [ ! -f $BASE_DIR/logs/skeptic.log ]; then
        echo "No skeptic logs found."
        exit 0
    fi
    echo "Recent Skeptic Evaluations:"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    tail -20 $BASE_DIR/logs/skeptic.log | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        d = json.loads(line.strip())
        print(f'{d[\"timestamp\"][:16]} | '
              f'{d[\"pair\"]:12} | '
              f'{d[\"decision\"]:5} | '
              f'{d[\"failure_confidence\"]*100:3.0f}% | '
              f'{d[\"primary_concern\"][:50]}')
    except:
        pass
"
    ;;
  test)
    echo "Running Skeptic test on BTC/USDT..."
    $BASE_DIR/venv/bin/python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/agents')
sys.path.insert(0, '$BASE_DIR/qnt/memory')
sys.path.insert(0, '$BASE_DIR/qnt/vault')
from trade_gate import evaluate_trade

test_proposal = {
    'pair': 'BTC/USDT',
    'strategy': 'MeanReversionV1',
    'direction': 'LONG',
    'entry_price': 94000.0,
    'stake_amount': 500.0,
    'rsi': 32.5,
    'sentiment_score': -0.15,
    'hmm_regime': 'RANGING',
    'order_flow_summary': 'neutral',
    'recent_candles': 'Last 5 candles: mixed'
}

result = evaluate_trade(test_proposal)
print(f'Decision: {result[\"decision\"]}')
print(f'Confidence: {result[\"failure_confidence\"]:.0%}')
print(f'Concern: {result[\"primary_concern\"]}')
print(f'Reasons: {result[\"reasons\"]}')
"
    ;;
  disable)
    sed -i '' 's/SKEPTIC_ENABLED = True/SKEPTIC_ENABLED = False/' $BASE_DIR/qnt/agents/trade_gate.py
    echo "Skeptic agent DISABLED"
    ;;
  enable)
    sed -i '' 's/SKEPTIC_ENABLED = False/SKEPTIC_ENABLED = True/' $BASE_DIR/qnt/agents/trade_gate.py
    echo "Skeptic agent ENABLED"
    ;;
  *)
    echo "Usage: qnt-skeptic [stats|log|test|enable|disable]"
    ;;
esac

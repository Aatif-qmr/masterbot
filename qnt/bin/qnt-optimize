#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
set -a
source $BASE_DIR/.env
set +a
STRATEGY=${1:-MeanReversionV1}
EPOCHS=${2:-200}
$BASE_DIR/qnt/bin/qnt-python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/lab')
sys.path.insert(0, '$BASE_DIR/qnt/memory')
sys.path.insert(0, '$BASE_DIR/qnt/bridge')
sys.path.insert(0, '$BASE_DIR/qnt/shield')
from lab import optimize_strategy
optimize_strategy('$STRATEGY', $EPOCHS)
"

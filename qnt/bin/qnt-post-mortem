#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
set -a
source $BASE_DIR/.env
set +a
TRADE_ID=${1}
if [ -z "$TRADE_ID" ]; then
  echo "Usage: qnt-post-mortem <trade_id>"
  echo "       qnt-post-mortem weekly (for weekly summary)"
  exit 1
fi
$BASE_DIR/qnt/bin/qnt-python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/vault')
sys.path.insert(0, '$BASE_DIR/qnt/memory')
sys.path.insert(0, '$BASE_DIR/qnt/oracle')
from post_mortem import generate_post_mortem, generate_weekly_post_mortem
if '$TRADE_ID' == 'weekly':
    print(generate_weekly_post_mortem())
else:
    print(generate_post_mortem(int('$TRADE_ID')))
"

#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
# qnt logs [--follow] [--lines N]

set -a
source $BASE_DIR/.env
set +a

FOLLOW=False
LINES=50

for arg in "$@"; do
  case $arg in
    --follow|-f) FOLLOW=True ;;
    --lines=*) LINES="${arg#*=}" ;;
  esac
done

$BASE_DIR/qnt/bin/qnt-python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/bridge')
sys.path.insert(0, '$BASE_DIR/qnt/memory')
from bridge import stream_logs
stream_logs(lines=$LINES, follow=$FOLLOW)
"

#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
set -a
source $BASE_DIR/.env
set +a

SUBCMD=${1:-run}

case $SUBCMD in
  run)
    echo "Running full Cloud (R2 + Google Drive) backup..."
    $BASE_DIR/venv/bin/python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/backup')
from r2_backup import run_full_backup
run_full_backup()
"
    ;;
  list)
    $BASE_DIR/venv/bin/python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/backup')
from r2_backup import list_backups
list_backups()
"
    ;;
  restore)
    $BASE_DIR/venv/bin/python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/backup')
from r2_backup import restore_latest_sqlite
restore_latest_sqlite()
"
    ;;
  *)
    echo "Usage: qnt-backup [run|list|restore]"
    ;;
esac

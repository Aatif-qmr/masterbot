#!/bin/bash
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
set -a
source $BASE_DIR/.env
set +a
HYPOTHESIS="$*"
if [ -z "$HYPOTHESIS" ]; then
  echo "Usage: qnt-strategy-gen <hypothesis>"
  echo "Example: qnt-strategy-gen Buy when RSI oversold and volume rising"
  exit 1
fi
$BASE_DIR/qnt/bin/qnt-python -c "
import sys
sys.path.insert(0, '$BASE_DIR/qnt/lab')
sys.path.insert(0, '$BASE_DIR/qnt/memory')
sys.path.insert(0, '$BASE_DIR/qnt/bridge')
sys.path.insert(0, '$BASE_DIR/qnt/shield')
from lab import generate_strategy
result = generate_strategy('''$HYPOTHESIS''')
print(f'Generated: {result}' if result else 'Generation failed')
"
